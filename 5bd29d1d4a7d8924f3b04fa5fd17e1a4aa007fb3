      "message": "this block (and 169-\u003e175) is similar to the original code in 95-114.\n\nTo avoid code duplication could you change the organization into:\nuint8_t* WebPRescalerExportRow(WebPRescaler* const wrk) {\n  if (wrk-\u003ey_accum \u003c\u003d 0) {\n    int x_out \u003d 0;\n    uint8_t* const dst \u003d wrk-\u003edst; \n    int32_t* const irow \u003d wrk-\u003eirow;\n    const int32_t* const frow \u003d wrk-\u003efrow;\n    const int yscale \u003d wrk-\u003efy_scale * (-wrk-\u003ey_accum);\n    const int x_out_max \u003d wrk-\u003edst_width * wrk-\u003enum_channels;\n\n#if defined(__mips__)\n    if ((wrk-\u003efxy_scale \u003e\u003e 32) \u003d\u003d 0) {\n        ...  MIPS-specific code here\n      x_out \u003d x_out_max;   // this will make the following for() code be skipped\n   }\n#endif   // __mips__\n \n    for (; x_out \u003c x_out_max; ++x_out) {\n      const int frac \u003d (int)MULT_FIX(frow[x_out], yscale);\n      const int v \u003d (int)MULT_FIX(irow[x_out] - frac, wrk-\u003efxy_scale);\n      dst[x_out] \u003d (!(v \u0026 ~0xff)) ? v : (v \u003c 0) ? 0 : 255;\n      irow[x_out] \u003d frac;   // new fractional start\n    }\n    wrk-\u003ey_accum +\u003d wrk-\u003ey_add;\n    wrk-\u003edst +\u003d wrk-\u003edst_stride;\n    return dst;\n  } else {\n    return NULL;\n  }\n}\n\n\nplease?",
