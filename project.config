[access]
	inheritFrom = webm
[receive]
	requireChangeId = true
[submit]
	mergeContent = true
[project]
[access "refs/tags/*"]
	createSignedTag = group webm-releasers
[access "refs/heads/*"]
	create = group webm-admins
	push = group webm-admins
[access "refs/for/*"]
	publishDrafts = group webm-admins
	deleteDrafts = group webm-admins
	label-Verified = -1..+1 group webm-googlers
